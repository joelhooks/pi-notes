{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/codex-brain-law.mjs\"",
            "timeout": 5,
            "statusMessage": "Loading pi-notes Brain law"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/codex-brain-law.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking pi-notes Brain context"
          }
        ]
      }
    ]
  }
}
