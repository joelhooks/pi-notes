{
  "name": "pi-notes",
  "version": "0.0.0",
  "description": "Pi extension for local Brain review pages, data-backed notes, and browser-to-agent feedback batches",
  "type": "module",
  "license": "MIT",
  "author": "Joel Hooks",
  "homepage": "https://github.com/joelhooks/pi-notes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelhooks/pi-notes.git"
  },
  "bugs": {
    "url": "https://github.com/joelhooks/pi-notes/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "brain",
    "local-notes",
    "review-documents",
    "mdsvex",
    "sveltekit"
  ],
  "bin": {
    "pi-notes": "./bin/pi-notes.ts"
  },
  "files": [
    "BRAIN.md",
    "VISION.md",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    ".codex-plugin/",
    "bin/",
    "docs/adr/",
    "docs/assets/",
    "docs/diagrams/",
    "examples/",
    "hooks/",
    "README.md",
    "extensions/",
    "skills/",
    "scripts/",
    "src/",
    "templates/",
    "svelte.config.js",
    "vite.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "vite dev --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "brain:check": "bun bin/pi-notes.ts brain check",
    "rig:install": "bun bin/pi-notes.ts rig install",
    "notes:inbox": "bun bin/pi-notes.ts inbox",
    "diagram:compile": "bun bin/pi-notes.ts diagram compile",
    "mermaid:render": "bun bin/pi-notes.ts mermaid render",
    "mermaid:clean": "bun bin/pi-notes.ts mermaid clean",
    "test": "vitest run"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-notes/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/svelte": "^1.1.2",
    "@libsql/client": "^0.17.3",
    "@sveltejs/adapter-node": "latest",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "latest",
    "@tldraw/mermaid": "^5.1.1",
    "@types/node": "latest",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.2",
    "bits-ui": "latest",
    "clsx": "latest",
    "effect": "latest",
    "layerchart": "^1.0.13",
    "lucide-svelte": "latest",
    "marked": "^18.0.3",
    "mdsvex": "latest",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-frontmatter": "^5.0.0",
    "sanitize-html": "^2.17.4",
    "shiki": "^4.0.2",
    "svelte": "latest",
    "tailwind-merge": "latest",
    "tailwindcss": "latest",
    "tldraw": "^5.1.1",
    "typescript": "latest",
    "unist-util-visit": "^5.1.0",
    "vite": "latest",
    "vitest": "latest",
    "xstate": "latest"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "latest",
    "prettier-plugin-svelte": "latest",
    "svelte-check": "latest",
    "typebox": "*"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@earendil-works/pi-ai": "*",
    "typebox": "*"
  },
  "packageManager": "bun@1.2.0"
}
